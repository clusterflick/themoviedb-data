{"id":1649037,"retrievedAt":"2026-03-10T11:52:38.557Z","response":{"adult":false,"backdrop_path":"/qaW2WgQPR01VRtFHxMOIp4BxhcT.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"},{"id":16,"name":"Animation"}],"homepage":"","id":1649037,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"Staatsräson","overview":"Building on testimony from pro-Palestinian activists in Berlin and featuring demonstration footage from between 2023 and 2025, this animated documentary explores activist culture and the people who have spent the past 2 years clashing with German police. By applying an expressive and colourful brush stroke to the experiences and anecdotes of two people closely involved with the movement, we look into the motivations that have driven them to get involved and their reactions to the repression they have experienced. Staatsraison attempts to shine light on police violence and explore how repression can drive someone ever further into a political movement.","popularity":0.0143,"poster_path":"/5kGyukgNCetmq31xrVB4SixQkib.jpg","production_companies":[{"id":257410,"logo_path":null,"name":"Leeds Arts University","origin_country":""}],"production_countries":[{"iso_3166_1":"GB","name":"United Kingdom"}],"release_date":"2026-02-20","revenue":0,"runtime":3,"spoken_languages":[],"status":"Released","tagline":"","title":"Staatsräson","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[{"iso_3166_1":"GB","title":"Staatsrason","type":""},{"iso_3166_1":"GB","title":"Staatsraison","type":""}]},"credits":{"cast":[{"adult":false,"gender":0,"id":6059452,"known_for_department":"Acting","name":"Max Graef (voice)","original_name":"Max Graef (voice)","popularity":0,"profile_path":null,"cast_id":6,"character":"self","credit_id":"69aeee6609bd8d499e45089d","order":0},{"adult":false,"gender":0,"id":6059453,"known_for_department":"Acting","name":"Nomi Sladko (voice","original_name":"Nomi Sladko (voice