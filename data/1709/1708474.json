{"id":1708474,"retrievedAt":"2026-06-05T14:13:17.738Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[],"homepage":"","id":1708474,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"Brockley and Ladywell Cemeteries","overview":"Brockley and Ladywell Cemeteries are the final resting place of thousands of our forebears. Established in the mid-nineteenth century, the cemeteries commemorate the dead as well as offering a vital green space for those seeking nature, solitude, or wonderfully rich grave iconography. This short documentary looks at users of the cemeteries and the attractions of its varied spaces. We also spend time with a small group interred here and who have gone before. Highlighted are: two poets, David Jones and Ernest Dowson; social reformers, Rachel and Margaret McMillan; and Maggie Khondoker, proprietor of Maggie’s Cafe, a Lewisham landmark. The living and the dead are not far apart.","popularity":0.0071,"poster_path":"/QCRKaIdRxUYOxN3m3I4370guqK.jpg","production_companies":[],"production_countries":[],"release_date":"2023-11-04","revenue":0,"runtime":5,"softcore":false,"spoken_languages":[],"status":"Released","tagline":"","title":"Brockley and Ladywell Cemeteries","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":0,"id":6264443,"known_for_department":"Acting","name":"Russell Potts","original_name":"Russell Potts","popularity":0,"profile_path":null,"cast_id":1,"character":"Narrator","credit_id":"6a220c99cc29688aa398ef80","order":0}],"crew":[{"adult":false,"gender":0,"id":6264447,"known_for_department":"Directing","name":"Andrew Dawson","original_name":"Andrew Dawson","popularity":0.0071,"profile_path":null,"credit_id":"6a220cf6872c4a70f994328d","department":"Directing","job":"Director"},{"adult":false,"gender":0,"id":6264447,"known_for_department":"Directing","name":"Andrew Dawson","original_name":