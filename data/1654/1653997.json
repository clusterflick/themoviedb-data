{"id":1653997,"retrievedAt":"2026-03-19T11:55:11.615Z","response":{"adult":false,"backdrop_path":"/xwwTEfGzgf7moXVzE6tIk42PQE6.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1653997,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"The Roots That Bind Us","overview":"The Roots that Bind Us explores the origins of non-unanimous juries in Louisiana and the impact of this racist law today. The film focuses on three men - Jermaine, Herman and Lloyd - whose fates were sealed before they were ever born. Through their stories, as well as expert testimony, archival research, animation, and poetry, the film exposes a system grown from the roots of slavery to incarcerate Black people. The film elevates the voices of those who fought and continue to fight for the justice that's owed to hundreds of people incarcerated all over Louisiana today.","popularity":0.0143,"poster_path":null,"production_companies":[],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"2026-03-11","revenue":0,"runtime":94,"spoken_languages":[],"status":"Released","tagline":"","title":"The Roots That Bind Us","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":0,"id":6080214,"known_for_department":"Acting","name":"calvin duncan","original_name":"calvin duncan","popularity":0,"profile_path":null,"cast_id":1,"character":"","credit_id":"69babf873c7fc642ce21ed3d","order":0},{"adult":false,"gender":0,"id":6080215,"known_for_department":"Acting","name":"Jermaine Hudson","original_name":"Jermaine Hudson","popularity":0,"profile_path":null,"cast_id":2,"character":"","credit_id":"69babf8ff54fb3e9f89b3451","order":1}],"crew":[{"adult":false,"gender":0,"id":6080216,"known_for_department":"Directing","name":"Sara Gozalo","original_name":"Sara Gozalo","popularity":0,"profile_path":null,"credit_id":"69babfb208c53c6c3