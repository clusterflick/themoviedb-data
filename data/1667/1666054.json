{"id":1666054,"retrievedAt":"2026-04-09T12:15:38.959Z","response":{"adult":false,"backdrop_path":"/2bGk4RrWriE3V5edARSieADGVfl.jpg","belongs_to_collection":null,"budget":35,"genres":[{"id":18,"name":"Drama"}],"homepage":"","id":1666054,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"Loop","overview":"Loop is an experimental noir short film that portrays the primordial and eternal story of humanity within the claustrophobic silence of a timeless, high-ceilinged room. The film follows a fallen soul (Adam) as he strives to leave a \"yellow\" trace of life upon a monochromatic world and struggles to seal his destiny through the keys of a typewriter. As the rhythmic clicks of the typewriter transform into a divine ritual, Adam realizes that \"solitude\" is the last and most painful name he has ever learned, before yielding his place to the next link in the chain (Eve). \"Loop\" is a layered existential tale suggesting that every end is a beginning, and every voice eventually dissolves into a profound silence (Lal).","popularity":0.2143,"poster_path":"/yqJj5JPJvMZ3i4CbVwCk9lz9Ktd.jpg","production_companies":[],"production_countries":[],"release_date":"","revenue":0,"runtime":10,"spoken_languages":[],"status":"Released","tagline":"","title":"Loop","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[{"iso_3166_1":"TR","title":"Döngü","type":""}]},"credits":{"cast":[{"adult":false,"gender":0,"id":6127188,"known_for_department":"Acting","name":"Bekir Doğan","original_name":"Bekir Doğan","popularity":0.0143,"profile_path":null,"cast_id":2,"character":"Adam","credit_id":"69d6570893ceb693c0cc094e","order":0},{"adult":false,"gender":0,"id":6127190,"known_for_department":"Acting","name":"Rumeysa Duman","original_name":"Rumeysa Duman","popularity":0.0143,"profile_path":null,"cast_id":3,"character":"Eve","credit_id":"69d6572111de2167bdf6654e","order":1}],"crew":[{"adult":false,"gender":0,"id":6127187,"known_for_department":