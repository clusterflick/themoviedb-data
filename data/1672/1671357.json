{"id":1671357,"retrievedAt":"2026-04-15T12:16:03.554Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"},{"id":10402,"name":"Music"}],"homepage":"","id":1671357,"imdb_id":null,"origin_country":["PT"],"original_language":"pt","original_title":"\"Percursos Alternativos\" - Ecos de Garagem: o Rock em Viseu nos anos 80 e 90","overview":"Across the country, many garages were emptied of cars to be filled with drums, basses, guitars, and amplifiers in the 1980s and 1990s. Before studios, often with no one really knowing how to play very well and without a plan, many bands started and ended in garages. What mattered was playing. Each decade has its own sound. In the 1980s and 1990s, it was that of alternative rock and its many variations. This is the story of the garage bands of Viseu, many of them local in scope, several reaching national dimension.","popularity":0.0143,"poster_path":"/6rtyuJjxyFcA9FANdY9taA0hPuY.jpg","production_companies":[{"id":295339,"logo_path":null,"name":"Gira Sol Azul","origin_country":""}],"production_countries":[{"iso_3166_1":"PT","name":"Portugal"}],"release_date":"2026-05-06","revenue":0,"runtime":92,"spoken_languages":[{"english_name":"Portuguese","iso_639_1":"pt","name":"Português"}],"status":"Post Production","tagline":"","title":"\"Alternative Routes\" – Viseu Garage's Rock Echoes from the 80s and 90s","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[],"crew":[{"adult":false,"gender":0,"id":6142360,"known_for_department":"Directing","name":"Rui Mota Pinto","original_name":"Rui Mota Pinto","popularity":0,"profile_path":null,"credit_id":"69de906a4efe490de69b946a","department":"Directing","job":"Director"},{"adult":false,"gender":0,"id":6142362,"known_for_department":"Sound","name":"Gustavo Dinis","original_name":"Gustavo Dinis","popularity":0,"profile_path":null,"credit_id":"69de90913597fb3728028546","department":"S