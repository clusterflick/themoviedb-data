{"id":1663356,"retrievedAt":"2026-04-04T11:49:41.741Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[],"homepage":"","id":1663356,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"Spin!","overview":"A love story, horror film, or perhaps a comedy, Spin! explores the extremes of consciousness arising from unmediated contact and intimacy with our manufactured ecology. Shot entirely in the first person, the film abandons the strictures of plot to focus instead on the lightness and gravity of a subject’s fleeting relationships with plumbing fixtures, clocks, spectators, vending machines, rabbits, dustbins, directional signs, guards, hand dryers, and with the two cities of dreams—Los Angeles and New York—which feature not merely as backdrops, but as main characters in their own right. Sustained throughout by Welch's Apple Juice, our bandaged entity is someone you’ll find disconcertingly familiar if you manage to spin around to look at yourself.","popularity":0,"poster_path":null,"production_companies":[],"production_countries":[],"release_date":"2026-04-18","revenue":0,"runtime":30,"spoken_languages":[],"status":"Released","tagline":"","title":"Spin!","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":0,"id":6117004,"known_for_department":"Acting","name":"Matthew Goldin","original_name":"Matthew Goldin","popularity":0,"profile_path":null,"cast_id":1,"character":"Don Sawyer","credit_id":"69d07a9b01c75acaaf0ba12e","order":0}],"crew":[{"adult":false,"gender":0,"id":6117004,"known_for_department":"Acting","name":"Matthew Goldin","original_name":"Matthew Goldin","popularity":0,"profile_path":null,"credit_id":"69d093f4f6f9028c1b9a1e98","department":"Directing","job":"Director"},{"adult":false,"gender":0,"id":1782180,"known_for_department":"Acting","name":"Jay Speedy Weingarten","original_name":"Jay Speedy Weingarten","popula