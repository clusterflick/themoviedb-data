{"id":1647278,"retrievedAt":"2026-03-07T11:40:01.776Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1647278,"imdb_id":"tt14346308","origin_country":["YU"],"original_language":"sh","original_title":"Dječak i konj","overview":"Film about friendship between a boy and a horse. The boy and his horse love and trust each other and spend their time together running in the fields. But the boy's father decides to sell the horse because he can no longer financially justify keeping it. His son's tears won't make him change his mind. The horse is sold. After returning from school, the boy starts searching for the horse: he looks in the barn, in the yard, in the fields, even at a market. But it is all in vain. Finally, the boy finds the horse at a railway station, already inside a train wagon. A tractor driver meets the boy who is lonely and sad and shows understanding for his pain. A new friendship is born.","popularity":0.0071,"poster_path":"/7vdIwPbm4EBs7d8asqibTD9SxD6.jpg","production_companies":[{"id":28713,"logo_path":null,"name":"Sutjeska Film","origin_country":"YU"}],"production_countries":[{"iso_3166_1":"YU","name":"Yugoslavia"}],"release_date":"1961-07-06","revenue":0,"runtime":8,"spoken_languages":[{"english_name":"Serbo-Croatian","iso_639_1":"sh","name":""}],"status":"Released","tagline":"","title":"A Boy and a Horse","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[],"crew":[{"adult":false,"gender":0,"id":1640394,"known_for_department":"Editing","name":"Vladimir Balvanović","original_name":"Vladimir Balvanović","popularity":0.0071,"profile_path":null,"credit_id":"69aac9d388d929661077c77b","department":"Directing","job":"Director"},{"adult":false,"gender":0,"id":1579488,"known_for_department":"Writing","name":"Vlatko Vlatković","original_name":"Vlatko Vlatković","popularity":0.0143,"profile_path":null,"credit_id":"69