{"id":1698606,"retrievedAt":"2026-05-20T13:57:31.684Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1698606,"imdb_id":null,"origin_country":["TW"],"original_language":"zh","original_title":"世紀的容顏：快門三劍客","overview":"Deng Nan-guang (鄧南光, 1907–1971), Chang Tsai (張才, 1916–1994), and Lee Ming-tiao (李鳴鵰, 1922–2013) are regarded as three of the most important prewar-generation photographers in Taiwanese photographic history, collectively known as the “Three Musketeers of Photography”. Directed by Chang Chao-Tang (張照堂), this documentary revisits their artistic trajectories, photographic styles, historical contexts, and contributions to the development of documentary photography in Taiwan. Particularly valuable are the interview segments featuring Chang Tsai and Lee Ming-tiao themselves, which preserve rare firsthand testimonies from two pivotal figures in early Taiwanese realist photography.","popularity":0.0071,"poster_path":"/pSj3uhbFZ4KBp4xEDhZFZxoAgdr.jpg","production_companies":[],"production_countries":[],"release_date":"2001-05-15","revenue":0,"runtime":57,"softcore":false,"spoken_languages":[],"status":"Released","tagline":"","title":"Faces of the Century: The Three Musketeers of Taiwanese Photography","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"external_ids":{"imdb_id":null,"wikidata_id":null,"facebook_id":null,"instagram_id":null,"twitter_id":null},"credits":{"cast":[{"adult":false,"gender":0,"id":6225485,"known_for_department":"Acting","name":"張才","original_name":"張才","popularity":0,"profile_path":null,"cast_id":2,"character":"","credit_id":"6a0ca83ede750e4a86edacbc","order":0},{"adult":false,"gender":0,"id":2444450,"known_for_department":"Camera","name":"Deng Nan-guang","original_name":"Deng Nan-guang","popularity":0.0143,"profile_path":null,"cast_id":3,"character":"","credit_id":"6a0ca84ac87f77b5ed069932","order":1},{"adul