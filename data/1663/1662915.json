{"id":1662915,"retrievedAt":"2026-04-04T11:49:24.434Z","response":{"adult":false,"backdrop_path":"/t99QGS4ILMrxdh08Wnhgc3xldir.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":10402,"name":"Music"}],"homepage":"","id":1662915,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"Camel: Moonmadness","overview":"Moonmadness is the fourth studio album by English progressive rock band Camel. It was released in March 1976 on Decca and Gama Records and is their last album recorded by the group's original line-up of Andrew Latimer, Peter Bardens, Doug Ferguson, and Andy Ward. After reaching success with their previous album, the all-instrumental The Snow Goose, the band started on a follow-up and incorporated vocals and lyrics to the new music. Moonmadness has a loose concept with one track based on the personality of each band member: \"Air Born\" for Andrew Latimer, \"Chord Change\" for Peter Bardens, \"Another Night\" for Doug Ferguson, and \"Lunar Sea\" for Andy Ward. In 2018, 42 years after its release, Camel performed the album live in its entirety.","popularity":0.0143,"poster_path":"/kS8G4FOLipYNtXELUnUouEEpPBy.jpg","production_companies":[],"production_countries":[],"release_date":"1976-03-26","revenue":0,"runtime":39,"spoken_languages":[],"status":"Released","tagline":"","title":"Camel: Moonmadness","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":2,"id":1423908,"known_for_department":"Acting","name":"Andrew Latimer","original_name":"Andrew Latimer","popularity":0.0429,"profile_path":null,"cast_id":1,"character":"","credit_id":"69cfaa4c52c7d9b566d29448","order":0},{"adult":false,"gender":0,"id":1423911,"known_for_department":"Acting","name":"Peter Bardens","original_name":"Peter Bardens","popularity":0.048,"profile_path":null,"cast_id":2,"character":"","credit_id":"69cfaa6195cc8413b9d29607","order":1},{"adult":false,"gender":0,"id":1423910,"known_for