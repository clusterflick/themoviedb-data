{"id":1728423,"retrievedAt":"2026-07-09T14:34:04.670Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1728423,"imdb_id":null,"origin_country":["ID"],"original_language":"id","original_title":"Jaga Tane Neket, Menjaga Warisan Ibu","overview":"The documentary follows the story of Lis Langobelen, young woman from Lamawara village on the island of Lembata, Lis is concerned that tradition of handloom weaving, passed on from her late mother and the foremothers before her, will soon die out. Only a few weavers still know how to process organic cotton into thread, prepare and use nature dyes and how to engage in gemohing (working together for a mutual benefit) in the production of a handloom textile. Lis learns about these ancient skills from the master weavers and in turn helps other weavers with their work in an effort to keep the tradition alive.","popularity":0,"poster_path":"/1DF5ZWsbDn1Ik63uF5fyYQnSmou.jpg","production_companies":[{"id":278646,"logo_path":null,"name":"Biru Terong Initiative","origin_country":""}],"production_countries":[{"iso_3166_1":"ID","name":"Indonesia"}],"release_date":"2017-11-24","revenue":0,"runtime":37,"softcore":false,"spoken_languages":[{"english_name":"Indonesian","iso_639_1":"id","name":"Bahasa indonesia"}],"status":"Released","tagline":"","title":"Preserving Mother's Legacy","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[],"crew":[{"adult":false,"gender":0,"id":2346957,"known_for_department":"Writing","name":"Vivian Idris","original_name":"Vivian Idris","popularity":0.0762,"profile_path":null,"credit_id":"6a4eee5cc48bac5d3c32331c","department":"Directing","job":"Director"},{"adult":false,"gender":0,"id":2346957,"known_for_department":"Writing","name":"Vivian Idris","original_name":"Vivian Idris","popularity":0.0762,"profile_path":null,"credit_id":"6a4eee65ed05aa6cf5a0900d","department":