{"id":1735584,"retrievedAt":"2026-07-22T12:45:38.177Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":440000,"genres":[],"homepage":"","id":1735584,"imdb_id":null,"origin_country":["IR"],"original_language":"fa","original_title":"Larissa","overview":"LARISSA tells the story of a young Afghan refugee girl sold—along with her family—to a powerful landowner, Davood Kan, in Iran. Forced into backbreaking work alongside dozens of undocumented migrants, Larissa’s intelligence and beauty draw the landowner’s attention. Pulled from the fields, she is promised protection and privilege — but at a devastating cost. When she resists his escalating abuse, the illusion of safety shatters. What begins as a quiet attempt to endure becomes a perilous struggle for dignity. Told through a raw and intimate lens, LARISSA is not just the story of one girl but a reflection of countless hidden lives. It confronts the exploitation, silence, and systemic violence faced by Afghan refugees in Iran and other countries, while honoring the resilience of those who refuse to be erased.","popularity":0.0071,"poster_path":"/ZkXn87qHz6nJcBTNNiHmbOLEcX.jpg","production_companies":[],"production_countries":[],"release_date":"2026-04-30","revenue":0,"runtime":90,"softcore":false,"spoken_languages":[{"english_name":"Persian","iso_639_1":"fa","name":"فارسی"}],"status":"Released","tagline":"","title":"Larissa","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":0,"id":6362668,"known_for_department":"Acting","name":"Golnaz Moradi","original_name":"Golnaz Moradi","popularity":0,"profile_path":null,"cast_id":1,"character":"Larissa","credit_id":"6a5fc482613db1f576d64837","order":0},{"adult":false,"gender":0,"id":1794539,"known_for_department":"Acting","name":"Siamak Adib","original_name":"Siamak Adib","popularity":0.1215,"profile_path":"/A3JuSS57F9qClFHEp0Y26DwPBLu.jpg","cast_id":2,"character":"Hormoz",