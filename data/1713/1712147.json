{"id":1712147,"retrievedAt":"2026-06-11T15:02:24.626Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1712147,"imdb_id":null,"origin_country":["US"],"original_language":"hi","original_title":"Sacred Walls-The Journey of Bhuri Bai","overview":"'Sacred Walls: The Journey of Bhuri Bai' is a documentary film by Sunil Babbar that chronicles the extraordinary life and artistic journey of Bhuri Bai, one of India's most celebrated Bhil artists. From her beginnings in a tribal community in Madhya Pradesh to becoming an internationally recognized painter, the film explores her transformation of traditional Bhil wall-painting practices into a distinctive contemporary art form. Through her personal story, artwork, and cultural heritage, the documentary highlights themes of resilience, identity, and the preservation of Indigenous traditions. Produced in association with North Central Zone Cultural Centre (NCZCC), the film celebrates the enduring spirit of tribal art and the visionary artist who brought it to the world stage. Bhuri Bai's journey from daily-wage laborer to acclaimed artist reflects the power of creativity to transcend social and cultural boundaries.","popularity":0.0286,"poster_path":null,"production_companies":[{"id":301255,"logo_path":null,"name":"NCZCC","origin_country":""}],"production_countries":[],"release_date":"2026-05-19","revenue":0,"runtime":26,"softcore":false,"spoken_languages":[],"status":"Released","tagline":"","title":"Sacred Walls-The Journey of Bhuri Bai","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":0,"id":4646843,"known_for_department":"Directing","name":"Sunil Babbar","original_name":"Sunil Babbar","popularity":0.0286,"profile_path":null,"cast_id":1,"character":"Bharatvasi","credit_id":"6a298c9caa17fd38928968f8","order":0},{"adult":false,"gender":0,"id":6276985,"known