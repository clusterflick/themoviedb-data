{"id":1720470,"retrievedAt":"2026-06-25T13:38:53.348Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1720470,"imdb_id":"tt30971551","origin_country":["DZ","BE"],"original_language":"en","original_title":"Assia Djebar, entre ombre et soleil","overview":"Algeria is written in the feminine. In a society where the gaze is only masculine, another eye is nonetheless present… The feminine gaze—unsettling, disturbing modesty, breaking taboos, freeing speech… It emerges from the shadows: with Assia Djebar, Algerian writer-historian, we go to meet Algerian women of all generations to enter into their lives, their daily routines, this world where the gaze is supposed to be forbidden. These women tell their own stories, imposing their gaze on the camera for a journey into this half of Algeria condemned to silence… to a clandestine life.","popularity":0.0143,"poster_path":"/hxL4mSS3Eftpc3HUwilwLy3QzPA.jpg","production_companies":[{"id":74735,"logo_path":"/xhBN3zrFBMZsRQibBK7BbI9J4gt.png","name":"CBA","origin_country":"BE"},{"id":27089,"logo_path":"/sTgxuOyyv2GafNDRFZQZ3XZCNC2.png","name":"Entreprise Nationale de Production Audiovisuelle (ENPA)","origin_country":"DZ"},{"id":792,"logo_path":"/cRhBQP1FFNugNxKkO1pUgeD2Rkr.png","name":"RTBF","origin_country":"BE"},{"id":302504,"logo_path":null,"name":"ZEAUX Productions","origin_country":""}],"production_countries":[{"iso_3166_1":"DZ","name":"Algeria"},{"iso_3166_1":"BE","name":"Belgium"}],"release_date":"1992-01-01","revenue":0,"runtime":52,"softcore":false,"spoken_languages":[{"english_name":"Arabic","iso_639_1":"ar","name":"العربية"},{"english_name":"French","iso_639_1":"fr","name":"Français"}],"status":"Released","tagline":"","title":"Assia Djebar, entre ombre et soleil","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":1,"id":1223385,"known_for_department":