{"id":1709182,"retrievedAt":"2026-06-06T12:26:57.375Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":878,"name":"Science Fiction"}],"homepage":"","id":1709182,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"Robotopia","overview":"Robotopia uses the same blend of magic realism and poetic journalism to unpick contemporary Japanese culture. Post-war Japan is viewed as a vortex that sucks in imagery, ideas and applications from all over the world and somehow translates them into diverting artefacts. For a country that never had an industrial revolution, Japan has a unique relationship to robots. Haggerty's investigation of the how and why of this phenomenon bravely slides us up and down the interface between humans behaving like robots and machine robots behaving like humans.","popularity":0,"poster_path":null,"production_companies":[],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"1990-01-01","revenue":0,"runtime":54,"softcore":false,"spoken_languages":[],"status":"Released","tagline":"","title":"Robotopia","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":0,"id":6266793,"known_for_department":"Acting","name":"Tetsuhisa Yamada","original_name":"Tetsuhisa Yamada","popularity":0,"profile_path":null,"cast_id":2,"character":"Self","credit_id":"6a2365ffbac399a733817411","order":0},{"adult":false,"gender":0,"id":3633534,"known_for_department":"Acting","name":"Frederik L. Schodt","original_name":"Frederik L. Schodt","popularity":0.0143,"profile_path":null,"cast_id":3,"character":"Self","credit_id":"6a23660dd898c8dca206ee85","order":1}],"crew":[{"adult":false,"gender":0,"id":5399669,"known_for_department":"Directing","name":"George Haggerty","original_name":"George Haggerty","popularity":0,"profile_path":null,"credit_id":"6a2365cbc528d471fcab5a02","department":"Direct