{"id":1652829,"retrievedAt":"2026-03-17T12:01:45.254Z","response":{"adult":false,"backdrop_path":"/vXhaLXG0dhvqmpGyq2ngwapyJyg.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1652829,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"Jerry Schatzberg","overview":"Jerry Schatzberg returned from serving in World War II and casually fell into photographing babies for his uncle’s diaper rental service and quickly gained early recognition by shooting aspiring models. When Alexander Liberman, art editor at Condé Nast contacted him, Schatzberg began his career as a fashion and celebrity photographer. He participated in a legendary series of classes given by Alexey Brodovich, along with such fellow students as Richard Avedon and Irving Penn. Schatzberg became one the key photographers of the Sixties zeitgeist—shooting Bob Dylan, the Rolling Stones, Frank Zappa, and Edie Sedgwick. In the 1970s he began directing films, including The Panic in Needle Park and Scarecrow.","popularity":0.0143,"poster_path":"/4Y64y6XzPcQXX3C4QXtnOpRUdBZ.jpg","production_companies":[],"production_countries":[],"release_date":"2025-06-22","revenue":0,"runtime":30,"spoken_languages":[],"status":"Released","tagline":"","title":"Jerry Schatzberg","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":2,"id":98199,"known_for_department":"Directing","name":"Jerry Schatzberg","original_name":"Jerry Schatzberg","popularity":1.1039,"profile_path":"/8rCnIrvgd4BvExqLwb200D9kIUU.jpg","cast_id":1,"character":"self","credit_id":"69b82a9047798715fc08f5cd","order":0},{"adult":false,"gender":2,"id":1487,"known_for_department":"Acting","name":"Bob Dylan","original_name":"Bob Dylan","popularity":1.0788,"profile_path":"/pMGkRge9jE0TRgENbUYt3N5qDPl.jpg","cast_id":2,"character":"photo arvhive","credit_id":"69b82a9842d2dfa5b45ca3e3","order":1},{"adult":false,"gende