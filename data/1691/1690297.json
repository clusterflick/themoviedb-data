{"id":1690297,"retrievedAt":"2026-05-08T12:28:06.330Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1690297,"imdb_id":null,"origin_country":["NZ"],"original_language":"en","original_title":"The Story of Seven-Hundred Polish Children","overview":"This 1967 documentary tells the story of 734 Polish children who were adopted by New Zealand in 1944 as WWII refugees. Moving interviews, filmed 20 years later, document their harrowing exodus from Poland: via Siberian labour camps, malnutrition and death, to being greeted by PM Peter Fraser on arrival in NZ. From traumatic beginnings the film chronicles new lives (as builders, doctors, educators, and mothers) and ends with a family beach picnic. Made for television, this was one of the last productions directed by pioneering woman filmmaker Kathleen O'Brien.","popularity":0.0071,"poster_path":null,"production_companies":[{"id":198170,"logo_path":null,"name":"The National Film Unit","origin_country":""}],"production_countries":[{"iso_3166_1":"NZ","name":"New Zealand"}],"release_date":"1967-01-01","revenue":0,"runtime":18,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"The Story of Seven-Hundred Polish Children","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"external_ids":{"imdb_id":null,"wikidata_id":null,"facebook_id":null,"instagram_id":null,"twitter_id":null},"credits":{"cast":[{"adult":false,"gender":0,"id":6197717,"known_for_department":"Acting","name":"Tim Eliott","original_name":"Tim Eliott","popularity":0,"profile_path":null,"cast_id":1,"character":"Narrator","credit_id":"69fd1d2983c9a82acc90c853","order":0}],"crew":[{"adult":false,"gender":0,"id":6197718,"known_for_department":"Directing","name":"Kathleen O'Brien","original_name":"Kathleen O'Brien","popularity":0,"profile_path":null,"credi