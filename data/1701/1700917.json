{"id":1700917,"retrievedAt":"2026-05-24T12:21:31.194Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[],"homepage":"","id":1700917,"imdb_id":null,"origin_country":["AT"],"original_language":"en","original_title":"China Girl","overview":"In an experimental deconstruction of filmic history, a fictional ‘china girl’ confronts the medium and industry that produced her orientalist name. Contrary to the term’s racial connotations, these anonymous models, used for the calibration of exposure and colour in film since the 1920s, were largely white. Drawing from this phenomena, ‘China Girl’ transforms one of cinema’s most invisible yet essential figures through a speculative manifesto on race, visibility, and narrative.","popularity":0.0143,"poster_path":null,"production_companies":[],"production_countries":[],"release_date":"","revenue":0,"runtime":15,"softcore":false,"spoken_languages":[],"status":"Released","tagline":"","title":"China Girl","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"external_ids":{"imdb_id":null,"wikidata_id":null,"facebook_id":null,"instagram_id":null,"twitter_id":null},"images":{"backdrops":[],"logos":[],"posters":[]},"keywords":{"keywords":[]},"credits":{"cast":[{"adult":false,"gender":0,"id":6234211,"known_for_department":"Acting","name":"Phoenix Tyler-Lee","original_name":"Phoenix Tyler-Lee","popularity":0,"profile_path":null,"cast_id":18,"character":"the China Girl","credit_id":"6a11995519dadd1bc5b5a5d5","order":0},{"adult":false,"gender":0,"id":6234212,"known_for_department":"Acting","name":"Charlotta Öberg","original_name":"Charlotta Öberg","popularity":0,"profile_path":null,"cast_id":19,"character":"White China Girl Model","credit_id":"6a1199759f8a2183db4026bd","order":1},{"adult":false,"gender":0,"id":6234213,"known_for_department":"Acting","name":"Stephan Sinn","original_name":"Stephan Sinn","popularity":0,"profile_path":null,"cast_id":20,"character":"Techni