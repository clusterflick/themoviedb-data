{"id":1732810,"retrievedAt":"2026-07-17T12:30:58.069Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"},{"id":12,"name":"Adventure"}],"homepage":"https://www.mntnfilm.com/en/film/untrodden-karakoram-1961","id":1732810,"imdb_id":null,"origin_country":["GB"],"original_language":"en","original_title":"Untrodden Karakoram","overview":"\"The 1961 RAF Karakoram Expedition was, like the 1955 RAF Expedition to Lahul, an exploratory expedition to an unknown region. The RAF team in 1961 did not do everything they intended. They did not climb K6, but at least contributed to human knowledge on this peak. With two 22,000 feet and two 20,000 feet summits attained, a glacier system opened up, and a good map, they have no reason to be disappointed with their results. The expedition consisted of twelve British climbers of whom eleven came from the RAF, and one guest climber.\"","popularity":0,"poster_path":"/lJV1m97WA8Bovc9FYWAQQGNZXTr.jpg","production_companies":[{"id":304643,"logo_path":null,"name":"Royal Air Force Mountaineering Association","origin_country":"GB"}],"production_countries":[],"release_date":"1961-12-01","revenue":0,"runtime":30,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"The 1961 expedition of the Royal Air Force mountaineering association","title":"Untrodden Karakoram","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":0,"id":6352076,"known_for_department":"Acting","name":"Tony Smyth","original_name":"Tony Smyth","popularity":0,"profile_path":null,"cast_id":1,"character":"self","credit_id":"6a599c3a932fe229856e991e","order":0},{"adult":false,"gender":0,"id":6352683,"known_for_department":"Acting","name":"Christopher Jonson","original_name":"Christopher Jonson","popularity":0,"profile_path":null,"cast_id":2,"character":"self","cred