{"id":1691327,"retrievedAt":"2026-05-10T12:11:46.623Z","response":{"adult":false,"backdrop_path":"/xBSfdyG1P7kOIaHWKuNpLb5hwID.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1691327,"imdb_id":"tt0235822","origin_country":["US"],"original_language":"en","original_title":"Tokende","overview":"Tokéndè (“We Are Going”), directed by Gerard De Boe for the 1958 Brussels World Expo, offers a vivid look at the Catholic missions in Belgian Congo. From the perilous journeys of early missionaries to the building of stone churches and thriving schools, the film showcases both struggles and achievements. Audiences see local welcomes, choruses, vocational training, and classrooms in action, culminating in the profession of a Black nun and the ordination of a Black priest. A sweeping, visually rich tribute to missionary work, the film balances historical reconstruction with educational and cultural celebration.","popularity":0.0143,"poster_path":"/u2PTlwC95vBND4R2Yo4E9efm7xc.jpg","production_companies":[{"id":297842,"logo_path":null,"name":"P.V.B.A. Produktie Gerard De Boe","origin_country":""}],"production_countries":[{"iso_3166_1":"BE","name":"Belgium"}],"release_date":"1958-01-01","revenue":0,"runtime":90,"softcore":false,"spoken_languages":[],"status":"Released","tagline":"","title":"Tokende","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[],"crew":[{"adult":false,"gender":2,"id":3731160,"known_for_department":"Directing","name":"Gérard De Boe","original_name":"Gérard De Boe","popularity":0,"profile_path":null,"credit_id":"69ff2c8ef4af116400ed7620","department":"Directing","job":"Director"},{"adult":false,"gender":0,"id":5812147,"known_for_department":"Camera","name":"Freddy Rents","original_name":"Freddy Rents","popularity":0.0071,"profile_path":null,"credit_id":"69ff5654e5f7f0cce6221727","department":"Crew","job":"Cinematography"},{"adult":false,"gender":0,"id":20775