{"id":1726055,"retrievedAt":"2026-07-05T12:37:17.973Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1726055,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"Déconnage","overview":"As part of the exhibition Critical Episodes (1957-2011). MACBA Collection, Level 2 of the Museum presents two new episodes of the MACBA Collection. One of these episodes is Déconnage, a video-essay by Angela Melitopoulos and Maurizio Lazzarato that looks at the life and work of the psychiatrist Francesc Tosquelles (1912-1994). In Déconnage, one of the pioneers of critical psychiatry in post-war Europe is introduced. Anti-psychiatry is recovered here through the figure of Francesc Tosquelles: a discourse and practice that address not mental illnesses, but vital, social and ethical problems. Anti-psychiatry foresaw the dysfunctions that would eventually afflict people in contemporary societies.","popularity":0.0071,"poster_path":"/xct8r2NeGb1XOutvstwqLwWssXd.jpg","production_companies":[],"production_countries":[],"release_date":"2023-01-01","revenue":0,"runtime":0,"softcore":false,"spoken_languages":[],"status":"Released","tagline":"","title":"Déconnage","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[{"adult":false,"gender":0,"id":5710638,"known_for_department":"Acting","name":"Francesc Tosquelles","original_name":"Francesc Tosquelles","popularity":0.0071,"profile_path":null,"cast_id":3,"character":"","credit_id":"6a49698e4b847731241fcec3","order":0}],"crew":[{"adult":false,"gender":0,"id":1880658,"known_for_department":"Writing","name":"Maurizio Lazzarato","original_name":"Maurizio Lazzarato","popularity":0.0143,"profile_path":null,"credit_id":"6a49697dd22b6dad0fe000f3","department":"Directing","job":"Director"},{"adult":false,"gender":0,"id":1880654,"known_for_department":"Directing","name":"Angela Meli