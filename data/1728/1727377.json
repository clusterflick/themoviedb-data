{"id":1727377,"retrievedAt":"2026-07-07T13:43:23.342Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1727377,"imdb_id":null,"origin_country":["KR"],"original_language":"ko","original_title":"도심지를 지나며","overview":"Pass Through the City documents a tripartite performance staged by Park Hyunki in Daegu on March 22, 1981. Park fabricated two enormous stones out of resin and embedded mirrors onto their surfaces. One stone was installed on the floor of Maekhyang Gallery, while the other was loaded onto a sixteen-meter truck and driven through downtown Daegu for forty minutes. After the ride, the stone was moved to a busy sidewalk by a bank, where passersby touched its surface, gathered around it, and looked at themselves in the mirror. The work was recorded on 16mm film.","popularity":0,"poster_path":"/68TqNMzHeG3zm1e9RQkFDk8lopx.jpg","production_companies":[],"production_countries":[{"iso_3166_1":"KR","name":"South Korea"}],"release_date":"1981-03-22","revenue":0,"runtime":10,"softcore":false,"spoken_languages":[{"english_name":"No Language","iso_639_1":"xx","name":"No Language"}],"status":"Released","tagline":"","title":"Pass Through the City","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[],"crew":[{"adult":false,"gender":2,"id":6028801,"known_for_department":"Directing","name":"Park Hyunki","original_name":"Park Hyunki","popularity":0,"profile_path":"/eE9zVC87b3zWRQnsvR4srCjoh80.jpg","credit_id":"6a4c517144e34a039bd367d5","department":"Directing","job":"Director"}]},"external_ids":{"imdb_id":null,"wikidata_id":null,"facebook_id":null,"instagram_id":null,"twitter_id":null},"images":{"backdrops":[],"logos":[],"posters":[{"aspect_ratio":0.667,"height":3000,"iso_3166_1":null,"iso_639_1":null,"file_path":"/68TqNMzHeG3zm1e9RQkFDk8lopx.jpg","vote_average":0,"vote_count":0,"width":2000}]},"keywords":{"keywords":[]},"release