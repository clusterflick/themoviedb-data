{"id":1679047,"retrievedAt":"2026-04-23T12:18:58.409Z","response":{"adult":false,"backdrop_path":"/7ChG9B6TXmkUYAbqJvPwtLc80es.jpg","belongs_to_collection":null,"budget":150,"genres":[{"id":16,"name":"Animation"},{"id":18,"name":"Drama"}],"homepage":"","id":1679047,"imdb_id":null,"origin_country":["US"],"original_language":"en","original_title":"MamaMommyMother","overview":"A watercoloured meandering through the relationship between mother and daughter. Through the lens of hundreds of hand-painted frames, this film explores the visual and emotional distance between them.  This film is a larger manifestation of the exploration of our perception of the turmoil in our lives, how we engage with the times of sadness or solitude in the moment, and how we reflect on them once they’ve passed. In making this film, I reached the understanding that memory does not return whole but rather in soft, distorted pieces, and painting became my practice to stitching those scraps together. Ultimately, this process reveals that the stories we carry about our experiences are always changing, and that revisiting them, even through labour or solitude, can open a space for reflection that we often rarely allow ourselves.","popularity":0.0071,"poster_path":"/rpAXInTz8eCZnhF2o1K3nWLQTVW.jpg","production_companies":[],"production_countries":[],"release_date":"2025-12-05","revenue":0,"runtime":1,"softcore":false,"spoken_languages":[],"status":"Released","tagline":"A watercoloured meandering through the relationship between mother and daughter.","title":"MamaMommyMother","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[],"crew":[{"adult":false,"gender":1,"id":6160539,"known_for_department":"Directing","name":"Hana Nour-Eldin","original_name":"Hana Nour-Eldin","popularity":0.0071,"profile_path":"/2zUJaNZf7Z3xqltN33kNbYO3y1X.jpg","credit_id":"69e9159f6374ca8613a5a029","department":"Directing","job":"Director"},{"adult":false,"gender":1,"id":616053