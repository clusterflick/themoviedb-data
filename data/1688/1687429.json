{"id":1687429,"retrievedAt":"2026-05-04T12:41:17.801Z","response":{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[],"homepage":"https://www.helenannaflanagan.com/works/blood-sisters/","id":1687429,"imdb_id":null,"origin_country":["GB"],"original_language":"en","original_title":"Blood Sisters","overview":"Blood Sisters uses the concept of student fraternities and their traditional hazing rituals as a starting point to create a fictional initiation ceremony for four older women. Hazing rituals, which often involve forcing new members into humiliating acts, are used by fraternities to strengthen group cohesion and identity. This work delves into these rituals and explores related themes, including the abject physicality of a woman’s body, conformity, social pressure, age, and agency. Blood Sisters playfully examines power, humiliation, and hierarchies in relation to fear in public spaces, with a focus on shame as a tool to control and manipulate behaviour.","popularity":0.0071,"poster_path":"/wR7uLLrIeV1bXXISK9oWehxVKQT.jpg","production_companies":[],"production_countries":[],"release_date":"2020-01-01","revenue":0,"runtime":9,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"Blood Sisters","video":false,"vote_average":0,"vote_count":0,"alternative_titles":{"titles":[]},"credits":{"cast":[],"crew":[{"adult":false,"gender":0,"id":6186478,"known_for_department":"Directing","name":"Helen Anna Flanagan","original_name":"Helen Anna Flanagan","popularity":0,"profile_path":null,"credit_id":"69f76ce2c690a592f938da42","department":"Directing","job":"Director"},{"adult":false,"gender":0,"id":4532038,"known_for_department":"Directing","name":"Josefin Arnell","original_name":"Josefin Arnell","popularity":0,"profile_path":null,"credit_id":"69f76cf1c0c48d13c93a4cf4","department":"Directing","job":"Director"}]},"external_ids":{"imdb_id":null,"wikidata_id":n